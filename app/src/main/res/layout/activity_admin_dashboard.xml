<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Panel"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_manage_users"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kelola Pengguna"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btn_manage_transactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kelola Transaksi"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_manage_notifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kelola Notifikasi Publik"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_manage_products"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kelola Produk"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_manage_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kelola Setelan & Kontak"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_manage_bonus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kelola Bonus & Komisi"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>
